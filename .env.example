# ─── Discord ──────────────────────────────────────────────────────────────────
# Get this from the Discord Developer Portal → Your Application → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: your Discord server's ID for instant slash-command sync during dev.
# Leave blank to sync globally (works on all servers but takes up to 1 hour).
# Right-click your server icon → Copy Server ID (requires Developer Mode in Discord settings)
DEV_GUILD_ID=

# ─── Anthropic (Claude API) ───────────────────────────────────────────────────
# Get this from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Spotify ──────────────────────────────────────────────────────────────────
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Required for /concert import (Spotify OAuth). Must be added to the
# "Redirect URIs" list in your Spotify app's Developer Dashboard settings.
# The default below works out of the box with auth_spotify.py.
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Path to the Spotipy OAuth token cache generated by auth_spotify.py.
# Change this only if you need to store the file at a non-default location.
# SPOTIFY_CACHE_PATH=.spotify_cache

# ─── Ticketmaster ─────────────────────────────────────────────────────────────
# Free API key from https://developer.ticketmaster.com/ (5000 calls/day)
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# ─── TMDB (The Movie Database) ────────────────────────────────────────────────
# Free API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# For local development, SQLite requires no setup:
DATABASE_URL=sqlite:///./discord_bot.db

# For GCP Cloud SQL (PostgreSQL), use one of:
#   Direct TCP (when running locally with Cloud SQL Auth Proxy):
#     DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
#   Unix socket (when running on a GCP VM or Cloud Run):
#     DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
